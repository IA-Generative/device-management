#
# Registry pull-secret configuration used by:
#   ./scripts/k8s/create-registry-secret.sh <local|scaleway|dgx>
#
# Providers: dockerhub | scaleway | custom
REGISTRY_PROVIDER=dockerhub
REGISTRY_SECRET_NAME=regcred
REGISTRY_NAMESPACE=bootstrap

# dockerhub
REGISTRY_SERVER=https://index.docker.io/v1/
REGISTRY_USERNAME=your-dockerhub-username
REGISTRY_PASSWORD=your-dockerhub-password-or-token
REGISTRY_EMAIL=

# scaleway (use instead of dockerhub values above)
# REGISTRY_PROVIDER=scaleway
# REGISTRY_SERVER=rg.fr-par.scw.cloud/funcscwnspricelessmontalcinhiacgnzi
# REGISTRY_USERNAME=nologin
# REGISTRY_PASSWORD=<SCW_SECRET_KEY>

# custom
# REGISTRY_PROVIDER=custom
# REGISTRY_SERVER=registry.example.com
# REGISTRY_USERNAME=<username>
# REGISTRY_PASSWORD=<password>
