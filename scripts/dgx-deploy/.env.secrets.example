# .env.secrets — Secrets DGX
#
# Au premier déploiement, dumb-deploy.sh auto-génère tous les tokens
# marqués "auto". Vous n'avez rien à faire sauf remplir LLM_API_TOKEN
# si vous utilisez un LLM.
#
# Le mot de passe postgres est "postgres" par défaut (cohérent avec le
# pod postgres déployé). Changez-le seulement si vous avez un postgres
# externe avec un autre mot de passe.

POSTGRES_PASSWORD=postgres
LLM_API_TOKEN=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
