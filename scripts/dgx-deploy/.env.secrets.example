# .env.secrets — DGX deployment secrets
# Copy this file to .env.secrets and fill in the values.
# This file is read ONCE by dumb-deploy.sh to create the K8s Secret.
# On subsequent deploys, the existing secret is KEPT (not overwritten).
#
# To update a single key later:
#   kubectl -n bootstrap patch secret device-management-secrets \
#     --type=merge -p '{"stringData":{"KEY":"new-value"}}'
#
# To re-initialize all secrets from this file:
#   ./dumb-deploy.sh --reset-secrets

# ── Database ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=bootstrap
DATABASE_URL=postgresql://dev:dev@postgres:5432/bootstrap
DATABASE_ADMIN_URL=postgresql://postgres:changeme-strong-password@postgres:5432/postgres

# ── Relay auth tokens ────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DM_RELAY_PROXY_SHARED_TOKEN=changeme-relay-proxy-token
DM_RELAY_SECRET_PEPPER=changeme-relay-secret-pepper

# ── Queue admin token ─────────────────────────
DM_QUEUE_ADMIN_TOKEN=changeme-queue-admin-token

# ── Telemetry signing keys ────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DM_TELEMETRY_TOKEN_SIGNING_KEY=changeme-telemetry-signing-key
DM_TELEMETRY_UPSTREAM_KEY=changeme-telemetry-upstream-key

# ── LLM API token ────────────────────────────
LLM_API_TOKEN=

# ── Admin session secret ──────────────────────
# MUST be changed from default for OIDC to work in production
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SESSION_SECRET=changeme-admin-session-secret

# ── AWS / S3 (leave empty if not using S3) ────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
