server {
  listen 8080;
  server_name _;

  resolver 127.0.0.11 valid=10s;  # Docker embedded DNS (requis pour host.docker.internal)
  proxy_ssl_server_name on;
  proxy_http_version 1.1;

  location = /healthz {
    add_header Content-Type text/plain;
    return 200 'ok';
  }

  # JWKs are public material and can be exposed without relay credentials.
  location = /keycloak/protocol/openid-connect/certs {
    proxy_set_header User-Agent $http_user_agent;
    proxy_pass ${RELAY_KEYCLOAK_UPSTREAM}/protocol/openid-connect/certs$is_args$args;
  }

  location = /__relay_auth {
    internal;
    proxy_pass http://device-management:3001/relay/authorize;
    proxy_pass_request_body off;
    proxy_set_header Content-Length "";
    proxy_set_header X-Relay-Client $http_x_relay_client;
    proxy_set_header X-Relay-Key $http_x_relay_key;
    proxy_set_header X-Relay-Proxy-Token ${RELAY_PROXY_SHARED_TOKEN};
    proxy_set_header X-Relay-Target $relay_target;
    proxy_set_header X-Original-Method $request_method;
    proxy_set_header X-Original-URI $request_uri;
  }

  location ~ ^/keycloak/protocol/openid-connect/(auth|token|userinfo)$ {
    set $relay_target keycloak;
    auth_request /__relay_auth;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header Content-Type $http_content_type;
    proxy_set_header User-Agent $http_user_agent;
    proxy_pass ${RELAY_KEYCLOAK_UPSTREAM}/protocol/openid-connect/$1$is_args$args;
  }

  location ~ ^/llm/(.+)$ {
    set $relay_target llm;
    auth_request /__relay_auth;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header Content-Type $http_content_type;
    proxy_set_header User-Agent $http_user_agent;
    proxy_pass ${RELAY_LLM_UPSTREAM}/$1$is_args$args;
  }

  location ~ ^/mcr-api/(.+)$ {
    set $relay_target mcr-api;
    auth_request /__relay_auth;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header Content-Type $http_content_type;
    proxy_set_header User-Agent $http_user_agent;
    proxy_pass ${RELAY_MCR_API_UPSTREAM}/$1$is_args$args;
  }

  location = /telemetry/v1/traces {
    set $relay_target telemetry;
    auth_request /__relay_auth;
    proxy_set_header Authorization $http_authorization;
    proxy_set_header Content-Type $http_content_type;
    proxy_set_header User-Agent $http_user_agent;
    proxy_pass http://device-management:3001/telemetry/v1/traces$is_args$args;
  }

  location / {
    return 404;
  }
}
