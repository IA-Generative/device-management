# ⚠ GITIGNORED — valeurs réelles (secrets). Ne pas committer.
# App
DM_APP_ENV=dev
DM_CONFIG_ENABLED=true
PUBLIC_BASE_URL=http://localhost:8089
DM_PORT=3001
DM_QUEUE_ENABLED=true
DM_CONFIG_POLL_INTERVAL_SECONDS=2
DM_RUNTIME_CONFIG_EDITABLE=true
# Database (dedicated, persistent volume)
DATABASE_URL=postgresql://owui:owui@dm-postgres:5432/bootstrap
# --- Keycloak (owuicore-main, realm openwebui) — positionnement plugin ---
KEYCLOAK_REALM=openwebui
KEYCLOAK_CLIENT_ID=bootstrap-iassistant
# Plugin = client public/PKCE, redirige sur une boucle locale (28443-28452)
KEYCLOAK_REDIRECT_URI=http://localhost:28443/callback
KEYCLOAK_ALLOWED_REDIRECT_URI=http://localhost:28443/callback
# Issuer de validation des access tokens du plugin par le DM
AUTH_ISSUER_URL=http://localhost:8082/realms/openwebui
DM_AUTH_AUDIENCE=bootstrap-iassistant
DM_AUTH_VERIFY_ACCESS_TOKEN=true
DM_AUTH_JWKS_URL=http://host.docker.internal:8082/realms/openwebui/protocol/openid-connect/certs
# Admin UI : SSO réel Keycloak owuicore (client confidentiel admin-dm-ui, groupe admin-dm)
KEYCLOAK_ISSUER_URL=http://localhost:8082
ADMIN_OIDC_ISSUER_URL=http://host.docker.internal:8082/realms/openwebui
ADMIN_OIDC_PUBLIC_ISSUER_URL=http://localhost:8082/realms/openwebui
ADMIN_OIDC_CLIENT_ID=admin-dm-ui
ADMIN_OIDC_CLIENT_SECRET=<set-me>
ADMIN_REQUIRED_GROUP=admin-dm
# --- Relay-assistant (proxy SSO/relay du plugin -> Keycloak owuicore + DM) ---
DM_RELAY_ASSISTANT_URL=http://relay-assistant:8080
DM_RELAY_PROXY_SHARED_TOKEN=<set-me>
# LLM (Scaleway Generative APIs)
LLM_BASE_URL=https://api.scaleway.ai/a9158aac-8404-46ea-8bf5-1ca048cd6ab4/v1
LLM_API_TOKEN=<set-me>
DEFAULT_MODEL_NAME=gpt-oss-120b
# Bootstrap URLs (consommé par le plugin LibreOffice) -> instance locale
DM_BOOTSTRAP_URLS=http://localhost:8089
# Télémétrie -> Tempo/Grafana local
DM_TELEMETRY_ENABLED=true
DM_TELEMETRY_PUBLIC_ENDPOINT=/telemetry/v1/traces
DM_TELEMETRY_UPSTREAM_ENDPOINT=http://tempo:4318/v1/traces
DM_TELEMETRY_GRAFANA_URL=http://localhost:3030
DM_TELEMETRY_REQUIRE_TOKEN=false
DM_TELEMETRY_TOKEN_SIGNING_KEY=<set-me>
# Secrets / tokens internes (locaux, générés)
DM_CONFIG_SECRET_KEY=<set-me>
DM_QUEUE_ADMIN_TOKEN=<set-me>
DM_RELAY_SECRET_PEPPER=<set-me>
ADMIN_SESSION_SECRET=<set-me>
# Pod considéré disparu (reaper) après ce délai de silence
DM_CONFIG_POD_TTL_SECONDS=120
