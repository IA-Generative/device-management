# Public base URL used in config/config.json (via ${PUBLIC_BASE_URL})
PUBLIC_BASE_URL=http://localhost:3001
MODELNAME1=
MODELNAME2=
MODELNAME3=

# App settings
DM_APP_ENV=dev
DM_CONFIG_ENABLED=true
DM_CONFIG_PROFILE=dev
DM_ENROLL_URL=/enroll
DM_ALLOW_ORIGINS=*
DM_MAX_BODY_SIZE_MB=10
DM_PORT=3001
DM_RUNTIME_MODE=api
DM_UVICORN_WORKERS=1
DM_UVICORN_ACCESS_LOG=false
DM_UVICORN_TIMEOUT_KEEP_ALIVE=10

# Postgres queue
DM_QUEUE_ENABLED=true
DM_QUEUE_BATCH_SIZE=50
DM_QUEUE_POLL_INTERVAL_SECONDS=0.5
DM_QUEUE_LOCK_TTL_SECONDS=60
DM_QUEUE_DEFAULT_MAX_ATTEMPTS=8
DM_QUEUE_RETRY_BASE_SECONDS=2
DM_QUEUE_RETRY_MAX_SECONDS=300
DM_QUEUE_RETRY_JITTER_SECONDS=1.0
DM_QUEUE_ADMIN_TOKEN=
DM_METRICS_ENABLED=true

# Keycloak (local)
KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/bootstrap
KEYCLOAK_REALM=bootstrap
KEYCLOAK_CLIENT_ID=device-management-plugin

# Relay security (DM side)
DM_RELAY_ENABLED=true
DM_RELAY_KEY_TTL_SECONDS=2592000
DM_RELAY_ALLOWED_TARGETS_CSV=keycloak,config,llm,mcr-api,telemetry
DM_RELAY_REQUIRE_KEY_FOR_SECRETS=true
DM_RELAY_FORCE_KEYCLOAK_ENDPOINTS=false

# Relay upstream whitelist (relay-assistant nginx)
RELAY_PORT=8088
RELAY_KEYCLOAK_UPSTREAM=http://host.docker.internal:8080/realms/bootstrap
RELAY_LLM_UPSTREAM=https://api.gpu.minint.fr/v1
RELAY_MCR_API_UPSTREAM=https://mcr-api.fake-domain.name

# Local enroll storage
DM_STORE_ENROLL_LOCALLY=true
DM_ENROLL_DIR=/data/enroll

# Optional S3 (set DM_STORE_ENROLL_S3=true to enable)
DM_STORE_ENROLL_S3=false
DM_S3_BUCKET=bootstrap
DM_S3_PREFIX_ENROLL=enroll/
DM_S3_PREFIX_BINARIES=binaries/
DM_BINARIES_MODE=presign
DM_PRESIGN_TTL_SECONDS=300
DM_S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
AWS_REGION=fr-par

# Telemetry relay
DM_TELEMETRY_ENABLED=true
DM_TELEMETRY_PUBLIC_ENDPOINT=/telemetry/v1/traces
DM_TELEMETRY_AUTHORIZATION_TYPE=Bearer
DM_TELEMETRY_UPSTREAM_ENDPOINT=https://telemetry.minint.fr/v1/traces
DM_TELEMETRY_UPSTREAM_AUTH_TYPE=Bearer
DM_TELEMETRY_UPSTREAM_KEY=
DM_TELEMETRY_TOKEN_TTL_SECONDS=300
DM_TELEMETRY_TOKEN_SIGNING_KEY=change-me-strong-random-signing-key
DM_TELEMETRY_REQUIRE_TOKEN=true
DM_TELEMETRY_MAX_BODY_SIZE_MB=2

# Postgres
POSTGRES_DB=bootstrap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Adminer
ADMINER_PORT=8080

# Database URL for app (local compose)
DATABASE_URL=postgresql://dev:dev@postgres:5432/bootstrap
DATABASE_ADMIN_URL=postgresql://postgres:postgres@postgres:5432/postgres
