apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
# Gabarit LOCAL (dev). Copier en `env-secrets.yaml` (gitignored).
# Les valeurs ci-dessous sont des DÉFAUTS DE DEV non sensibles : utilisables tels quels
# en local (ne JAMAIS réutiliser en prod). La base ne fournit plus les secrets.
stringData:
  PUBLIC_BASE_URL: "http://bootstrap.home"
  DM_ENROLL_URL: "/enroll"
  KEYCLOAK_ISSUER_URL: "http://bootstrap.home/relay-assistant/keycloak"
  KEYCLOAK_REDIRECT_URI: "https://mysso.fake-domain.name/callback"
  KEYCLOAK_ALLOWED_REDIRECT_URI: "https://mysso.fake-domain.name/callback"

  # Tokens template extension (DM-2) — vides OK en local
  API_BASE: ""
  RELAY_ASSISTANT_BASE_URL: ""
  COMPTE_RENDU_URL: ""
  COMU_URL: ""
  TELEMETRY_ENDPOINT: ""
  TELEMETRY_KEY: ""
  TELEMETRY_SALT: ""

  # Secrets de dev (non sensibles) — valeurs jetables locales
  LLM_API_TOKEN: "dev-local-token"
  DM_QUEUE_ADMIN_TOKEN: "dev-queue-admin-token"
  DM_TELEMETRY_UPSTREAM_KEY: "dev-upstream-key"
  DM_TELEMETRY_TOKEN_SIGNING_KEY: "dev-signing-key-change-in-prod"
  DM_RELAY_PROXY_SHARED_TOKEN: "dev-relay-proxy-token"
  DM_RELAY_SECRET_PEPPER: "dev-relay-pepper"
  POSTGRES_PASSWORD: "postgres"
  DATABASE_URL: "postgresql://dev:dev@postgres:5432/bootstrap"
  DATABASE_ADMIN_URL: "postgresql://postgres:postgres@postgres:5432/postgres"
