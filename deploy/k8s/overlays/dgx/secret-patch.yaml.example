apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
# Gabarit DGX. Copier en `secret-patch.yaml` (gitignored) et renseigner les <CHANGEME>.
# La base ne contient plus de secret : cet overlay doit fournir TOUS les secrets.
stringData:
  PUBLIC_BASE_URL: "https://onyxia.gpu.minint.fr/bootstrap"   # préfixe /bootstrap !
  DM_ENROLL_URL: "/bootstrap/enroll"

  # Keycloak — realm mirai sur sso.mirai.interieur.gouv.fr (egress direct via proxy)
  KEYCLOAK_ISSUER_URL: "https://sso.mirai.interieur.gouv.fr"
  KEYCLOAK_REALM: "mirai"
  KEYCLOAK_CLIENT_ID: "bootstrap-iassistant"
  ADMIN_REQUIRED_GROUP: "/g/Iassistant-Device-management"
  # Callback OIDC flux bootstrap/LibreOffice (PAS l'extension). À confirmer : SSO vs onyxia.
  KEYCLOAK_REDIRECT_URI: "https://sso.mirai.interieur.gouv.fr/callback"
  KEYCLOAK_ALLOWED_REDIRECT_URI: "https://sso.mirai.interieur.gouv.fr/callback"
  ADMIN_OIDC_ISSUER_URL: "https://sso.mirai.interieur.gouv.fr/realms/mirai"
  ADMIN_OIDC_PUBLIC_ISSUER_URL: "https://sso.mirai.interieur.gouv.fr/realms/mirai"
  ADMIN_OIDC_REDIRECT_URI: "https://onyxia.gpu.minint.fr/admin/callback"
  DM_AUTH_JWKS_URL: "https://sso.mirai.interieur.gouv.fr/realms/mirai/protocol/openid-connect/certs"

  # Relay upstreams
  RELAY_KEYCLOAK_UPSTREAM: "https://sso.mirai.interieur.gouv.fr/realms/mirai"
  RELAY_COMPTE_RENDU_UPSTREAM: "https://compte-rendu.mirai.interieur.gouv.fr"
  DM_RELAY_ALLOWED_TARGETS_CSV: "keycloak,config,llm,mcr-api,telemetry,compte-rendu"
  RELAY_MCR_API_UPSTREAM: ""

  # LLM — API interne DGX (gpu.minint.fr, bypass proxy via no_proxy=.minint.fr)
  LLM_BASE_URL: "https://api.gpu.minint.fr/v1"
  RELAY_LLM_UPSTREAM: "https://api.gpu.minint.fr/v1"
  DEFAULT_MODEL_NAME: "<CHANGEME>"
  DM_TELEMETRY_GRAFANA_URL: ""

  # Tokens du template extension (DM-2)
  API_BASE: "<CHANGEME>"
  RELAY_ASSISTANT_BASE_URL: "<CHANGEME>"
  COMPTE_RENDU_URL: "<CHANGEME>"
  COMU_URL: "<CHANGEME>"
  TELEMETRY_ENDPOINT: "<CHANGEME>"
  TELEMETRY_KEY: "<CHANGEME>"
  TELEMETRY_SALT: "<CHANGEME>"

  # ── Secrets (déplacés hors de la base committée) ──────────────────────
  LLM_API_TOKEN: "<CHANGEME>"
  DM_QUEUE_ADMIN_TOKEN: "<CHANGEME>"
  DM_TELEMETRY_UPSTREAM_KEY: "<CHANGEME>"
  DM_TELEMETRY_TOKEN_SIGNING_KEY: "<CHANGEME>"
  DM_RELAY_PROXY_SHARED_TOKEN: "<CHANGEME>"
  DM_RELAY_SECRET_PEPPER: "<CHANGEME>"
  POSTGRES_PASSWORD: "<CHANGEME>"
  DATABASE_URL: "postgresql://dev:<CHANGEME>@postgres:5432/bootstrap"
  DATABASE_ADMIN_URL: "postgresql://postgres:<CHANGEME>@postgres:5432/postgres"
