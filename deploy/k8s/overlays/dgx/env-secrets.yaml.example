apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
# Gabarit DGX. Copier en `env-secrets.yaml` (gitignored) et renseigner les <CHANGEME>.
# La base ne contient plus de secret : cet overlay doit fournir TOUS les secrets.
stringData:
  PUBLIC_BASE_URL: "https://<PUBLIC_HOSTNAME>/bootstrap"   # préfixe /bootstrap !
  DM_ENROLL_URL: "/bootstrap/enroll"

  # Keycloak — realm mirai sur <SSO_HOSTNAME> (egress direct via proxy)
  KEYCLOAK_ISSUER_URL: "https://<SSO_HOSTNAME>"
  KEYCLOAK_REALM: "mirai"
  KEYCLOAK_CLIENT_ID: "bootstrap-iassistant"
  ADMIN_REQUIRED_GROUP: "/g/Iassistant-Device-management"
  # Callback OIDC flux bootstrap/LibreOffice (PAS l'extension). À confirmer : SSO vs onyxia.
  KEYCLOAK_REDIRECT_URI: "https://<SSO_HOSTNAME>/callback"
  KEYCLOAK_ALLOWED_REDIRECT_URI: "https://<SSO_HOSTNAME>/callback"
  ADMIN_OIDC_ISSUER_URL: "https://<SSO_HOSTNAME>/realms/mirai"
  ADMIN_OIDC_PUBLIC_ISSUER_URL: "https://<SSO_HOSTNAME>/realms/mirai"
  # ADMIN_OIDC_REDIRECT_URI n'est plus nécessaire : le callback admin est dérivé
  # dynamiquement de PUBLIC_BASE_URL (origin + /admin/callback). Pense à déclarer
  # cette URL dans les "Valid redirect URIs" du client Keycloak.
  DM_AUTH_JWKS_URL: "https://<SSO_HOSTNAME>/realms/mirai/protocol/openid-connect/certs"

  # Relay upstreams
  RELAY_KEYCLOAK_UPSTREAM: "https://<SSO_HOSTNAME>/realms/mirai"
  RELAY_COMPTE_RENDU_UPSTREAM: "https://<UPSTREAM_HOSTNAME>"
  DM_RELAY_ALLOWED_TARGETS_CSV: "keycloak,config,llm,mcr-api,telemetry,compte-rendu"
  RELAY_MCR_API_UPSTREAM: ""

  # LLM — API interne DGX (<INTERNAL_DOMAIN>, bypass proxy via no_proxy=.<INTERNAL_DOMAIN>)
  LLM_BASE_URL: "https://<LLM_API_HOSTNAME>/v1"
  RELAY_LLM_UPSTREAM: "https://<LLM_API_HOSTNAME>/v1"
  DEFAULT_MODEL_NAME: "<CHANGEME>"

  # Observabilité auto-hébergée (Tempo + Grafana dans le ns bootstrap)
  DM_TELEMETRY_UPSTREAM_ENDPOINT: "http://tempo:4318/v1/traces"
  DM_TELEMETRY_GRAFANA_URL: "https://<PUBLIC_HOSTNAME>/grafana/explore"
  GRAFANA_ADMIN_PASSWORD: "<CHANGEME>"
  # SSO Grafana : réutilise le client public bootstrap-iassistant (KEYCLOAK_CLIENT_ID),
  # pas de client secret (PKCE). Ajouter le redirect URI Grafana côté Keycloak.

  # Tokens du template extension (DM-2)
  API_BASE: "<CHANGEME>"
  RELAY_ASSISTANT_BASE_URL: "<CHANGEME>"
  COMPTE_RENDU_URL: "<CHANGEME>"
  COMU_URL: "<CHANGEME>"
  TELEMETRY_ENDPOINT: "<CHANGEME>"
  TELEMETRY_KEY: "<CHANGEME>"
  TELEMETRY_SALT: "<CHANGEME>"

  # ── Secrets (déplacés hors de la base committée) ──────────────────────
  LLM_API_TOKEN: "<CHANGEME>"
  DM_QUEUE_ADMIN_TOKEN: "<CHANGEME>"
  DM_TELEMETRY_UPSTREAM_KEY: "<CHANGEME>"
  DM_TELEMETRY_TOKEN_SIGNING_KEY: "<CHANGEME>"
  DM_RELAY_PROXY_SHARED_TOKEN: "<CHANGEME>"
  DM_RELAY_SECRET_PEPPER: "<CHANGEME>"
  POSTGRES_PASSWORD: "<CHANGEME>"
  DATABASE_URL: "postgresql://dev:<CHANGEME>@postgres:5432/bootstrap"
  DATABASE_ADMIN_URL: "postgresql://postgres:<CHANGEME>@postgres:5432/postgres"
