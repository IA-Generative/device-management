apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
stringData:
  PUBLIC_BASE_URL: "<CHANGEME>"
  DM_ENROLL_URL: "<CHANGEME>"

  # Keycloak — realm mirai on <SSO_HOSTNAME>
  KEYCLOAK_ISSUER_URL: "<CHANGEME>"
  KEYCLOAK_REALM: "<CHANGEME>"
  KEYCLOAK_CLIENT_ID: "<CHANGEME>"
  ADMIN_REQUIRED_GROUP: "<CHANGEME>"

  # Callback OIDC du flux bootstrap/LibreOffice (client bootstrap-iassistant).
  # PAS l'extension navigateur. Doit figurer dans « Valid redirect URIs » Keycloak.
  # ex. https://<SSO_HOSTNAME>/callback — NE PAS laisser localhost en prod.
  KEYCLOAK_REDIRECT_URI: "<CHANGEME>"
  KEYCLOAK_ALLOWED_REDIRECT_URI: "<CHANGEME>"

  # Internal Keycloak URL (via WireGuard proxy in-cluster)
  # Browser-facing URLs stay on <SSO_HOSTNAME>
  # Server-side calls go through the wireguard-proxy service
  ADMIN_OIDC_ISSUER_URL: "<CHANGEME>"
  ADMIN_OIDC_PUBLIC_ISSUER_URL: "<CHANGEME>"
  DM_AUTH_JWKS_URL: "<CHANGEME>"

  # Relay upstream (via WireGuard proxy)
  RELAY_KEYCLOAK_UPSTREAM: "<CHANGEME>"

  # LLM — Scaleway API
  LLM_API_TOKEN: "<CHANGEME>"
  LLM_BASE_URL: "<CHANGEME>"
  # Modèle non secret : valeur réelle persistée ici (source-of-truth pour
  # reconstruire l'overlay gitignored). Doit exister dans le catalogue Scaleway.
  DEFAULT_MODEL_NAME: "llama-3.3-70b-instruct"
  # Modèle d'embeddings (RAG via /llm/v1). Scaleway expose le nom littéral.
  EMBD_MODEL_NAME: "bge-multilingual-gemma2"
  # RELAY_LLM_UPSTREAM supprimé : plus de relais /llm, appel LLM direct côté
  # client via llm_base_urls (servi dans /config).

  # Tokens du template de l'extension navigateur (DM-2) — valeur RÉELLE obligatoire,
  # sinon le token sort vide dans config.json au runtime.
  API_BASE: "<CHANGEME>"
  RELAY_ASSISTANT_BASE_URL: "<CHANGEME>"
  COMPTE_RENDU_URL: "<CHANGEME>"
  COMU_URL: "<CHANGEME>"
  TELEMETRY_ENDPOINT: "<CHANGEME>"   # ex. https://<host>/telemetry/v1/traces
  TELEMETRY_KEY: "<CHANGEME>"
  TELEMETRY_SALT: "<CHANGEME>"

  # ── Secrets partagés (déplacés hors de la base committée) ──────────────
  # À fournir ici (gitignored). Pour ROTATIONNER les valeurs historiquement
  # exposées en git : LLM_API_TOKEN, DM_TELEMETRY_UPSTREAM_KEY, DM_TELEMETRY_TOKEN_SIGNING_KEY.
  DM_QUEUE_ADMIN_TOKEN: "<CHANGEME>"
  DM_TELEMETRY_UPSTREAM_KEY: "<CHANGEME>"
  DM_TELEMETRY_TOKEN_SIGNING_KEY: "<CHANGEME>"
  DM_RELAY_PROXY_SHARED_TOKEN: "<CHANGEME>"
  DM_RELAY_SECRET_PEPPER: "<CHANGEME>"
  # Base de données — reprendre la valeur EXISTANTE (ne pas rotationner sans migration du PVC).
  POSTGRES_PASSWORD: "<CHANGEME>"
  DATABASE_URL: "postgresql://dev:<CHANGEME>@postgres:5432/bootstrap"
  DATABASE_ADMIN_URL: "postgresql://postgres:<CHANGEME>@postgres:5432/postgres"
