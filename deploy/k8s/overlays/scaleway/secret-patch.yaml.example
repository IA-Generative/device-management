apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
stringData:
  PUBLIC_BASE_URL: "<CHANGEME>"
  DM_ENROLL_URL: "<CHANGEME>"

  # Keycloak — realm mirai on <SSO_HOSTNAME>
  KEYCLOAK_ISSUER_URL: "<CHANGEME>"
  KEYCLOAK_REALM: "<CHANGEME>"
  KEYCLOAK_CLIENT_ID: "<CHANGEME>"
  ADMIN_REQUIRED_GROUP: "<CHANGEME>"

  # Callback OIDC du flux bootstrap/LibreOffice (client bootstrap-iassistant).
  # PAS l'extension navigateur. Doit figurer dans « Valid redirect URIs » Keycloak.
  # ex. https://<SSO_HOSTNAME>/callback — NE PAS laisser localhost en prod.
  KEYCLOAK_REDIRECT_URI: "<CHANGEME>"
  KEYCLOAK_ALLOWED_REDIRECT_URI: "<CHANGEME>"

  # Internal Keycloak URL (via WireGuard proxy in-cluster)
  # Browser-facing URLs stay on <SSO_HOSTNAME>
  # Server-side calls go through the wireguard-proxy service
  ADMIN_OIDC_ISSUER_URL: "<CHANGEME>"
  ADMIN_OIDC_PUBLIC_ISSUER_URL: "<CHANGEME>"
  DM_AUTH_JWKS_URL: "<CHANGEME>"

  # Relay upstream (via WireGuard proxy)
  RELAY_KEYCLOAK_UPSTREAM: "<CHANGEME>"

  # LLM — Scaleway API
  LLM_API_TOKEN: "<CHANGEME>"
  LLM_BASE_URL: "<CHANGEME>"
  DEFAULT_MODEL_NAME: "<CHANGEME>"
  RELAY_LLM_UPSTREAM: "<CHANGEME>"

  # Tokens du template de l'extension navigateur (DM-2) — valeur RÉELLE obligatoire,
  # sinon le token sort vide dans config.json au runtime.
  API_BASE: "<CHANGEME>"
  RELAY_ASSISTANT_BASE_URL: "<CHANGEME>"
  COMPTE_RENDU_URL: "<CHANGEME>"
  COMU_URL: "<CHANGEME>"
  TELEMETRY_ENDPOINT: "<CHANGEME>"   # ex. https://<host>/telemetry/v1/traces
  TELEMETRY_KEY: "<CHANGEME>"
