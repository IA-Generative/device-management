apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
stringData:
  PUBLIC_BASE_URL: "<CHANGEME>"
  DM_ENROLL_URL: "<CHANGEME>"

  # Keycloak — realm mirai on <SSO_HOSTNAME>
  KEYCLOAK_ISSUER_URL: "<CHANGEME>"
  KEYCLOAK_REALM: "<CHANGEME>"
  KEYCLOAK_CLIENT_ID: "<CHANGEME>"
  ADMIN_REQUIRED_GROUP: "<CHANGEME>"

  # Internal Keycloak URL (via WireGuard proxy in-cluster)
  # Browser-facing URLs stay on <SSO_HOSTNAME>
  # Server-side calls go through the wireguard-proxy service
  ADMIN_OIDC_ISSUER_URL: "<CHANGEME>"
  ADMIN_OIDC_PUBLIC_ISSUER_URL: "<CHANGEME>"
  DM_AUTH_JWKS_URL: "<CHANGEME>"

  # Relay upstream (via WireGuard proxy)
  RELAY_KEYCLOAK_UPSTREAM: "<CHANGEME>"

  # LLM — Scaleway API
  LLM_API_TOKEN: "<CHANGEME>"
  LLM_BASE_URL: "<CHANGEME>"
  DEFAULT_MODEL_NAME: "<CHANGEME>"
  RELAY_LLM_UPSTREAM: "<CHANGEME>"
