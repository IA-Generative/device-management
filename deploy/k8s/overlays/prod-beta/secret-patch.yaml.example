apiVersion: v1
kind: Secret
metadata:
  name: device-management-secrets
  namespace: bootstrap
# Gabarit PROD-BETA. Copier en `secret-patch.yaml` (gitignored) et renseigner les <CHANGEME>.
# La base ne contient plus de secret : cet overlay doit fournir TOUS les secrets.
stringData:
  PUBLIC_BASE_URL: "<CHANGEME>"
  DM_ENROLL_URL: "<CHANGEME>"

  # Keycloak (realm mirai, comme la prod)
  KEYCLOAK_ISSUER_URL: "https://<INTERNAL_DOMAIN>"
  KEYCLOAK_REALM: "mirai"
  KEYCLOAK_CLIENT_ID: "bootstrap-iassistant"
  ADMIN_REQUIRED_GROUP: "/g/Iassistant-Device-management"
  KEYCLOAK_REDIRECT_URI: "https://<INTERNAL_DOMAIN>/callback"
  KEYCLOAK_ALLOWED_REDIRECT_URI: "https://<INTERNAL_DOMAIN>/callback"
  ADMIN_OIDC_ISSUER_URL: "<CHANGEME>"
  ADMIN_OIDC_PUBLIC_ISSUER_URL: "https://<INTERNAL_DOMAIN>/realms/mirai"
  DM_AUTH_JWKS_URL: "<CHANGEME>"
  RELAY_KEYCLOAK_UPSTREAM: "<CHANGEME>"

  # LLM
  LLM_BASE_URL: "<CHANGEME>"
  DEFAULT_MODEL_NAME: "<CHANGEME>"
  RELAY_LLM_UPSTREAM: "<CHANGEME>"

  # Tokens template extension (DM-2)
  API_BASE: "<CHANGEME>"
  RELAY_ASSISTANT_BASE_URL: "<CHANGEME>"
  COMPTE_RENDU_URL: "<CHANGEME>"
  COMU_URL: "<CHANGEME>"
  TELEMETRY_ENDPOINT: "<CHANGEME>"
  TELEMETRY_KEY: "<CHANGEME>"
  TELEMETRY_SALT: "<CHANGEME>"

  # ── Secrets (déplacés hors de la base committée) ──────────────────────
  LLM_API_TOKEN: "<CHANGEME>"
  DM_QUEUE_ADMIN_TOKEN: "<CHANGEME>"
  DM_TELEMETRY_UPSTREAM_KEY: "<CHANGEME>"
  DM_TELEMETRY_TOKEN_SIGNING_KEY: "<CHANGEME>"
  DM_RELAY_PROXY_SHARED_TOKEN: "<CHANGEME>"
  DM_RELAY_SECRET_PEPPER: "<CHANGEME>"
  POSTGRES_PASSWORD: "<CHANGEME>"
  DATABASE_URL: "postgresql://dev:<CHANGEME>@postgres:5432/bootstrap"
  DATABASE_ADMIN_URL: "postgresql://postgres:<CHANGEME>@postgres:5432/postgres"
