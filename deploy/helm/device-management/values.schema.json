{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "device-management",
  "type": "object",
  "additionalProperties": true,
  "required": ["image", "config"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": { "name": { "type": "string" } }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": { "type": "boolean" },
        "runAsUser": { "type": ["integer", "null"] },
        "runAsGroup": { "type": ["integer", "null"] },
        "fsGroup": { "type": ["integer", "null"] },
        "seccompProfileType": { "type": "string" }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "properties": {
        "allowPrivilegeEscalation": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "capabilities": { "type": "object" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "admin": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "existingClaim": { "type": "string" },
            "size": { "type": "string" }
          }
        }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "telemetryRelay": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 0 }
      }
    },
    "migration": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host", "paths"],
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path", "pathType", "service"],
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string", "enum": ["Prefix", "Exact", "ImplementationSpecific"] },
                    "service": { "type": "string", "enum": ["api", "admin", "telemetryRelay"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "required": ["app", "storage", "keycloak", "auth", "telemetry", "postgres"],
      "properties": {
        "keycloak": {
          "type": "object",
          "required": ["issuerUrl", "realm", "clientId"],
          "properties": {
            "issuerUrl": { "type": "string", "minLength": 1 },
            "realm": { "type": "string", "minLength": 1 },
            "clientId": { "type": "string", "minLength": 1 }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "binariesMode": { "type": "string", "enum": ["presign", "proxy", "local"] }
          }
        }
      }
    },
    "contentTemplate": { "type": "object" },
    "secrets": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" },
        "create": { "type": "boolean" },
        "values": { "type": "object" }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "internal": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    }
  }
}
